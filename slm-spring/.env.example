# ----- Base model (must match what the Modelfile FROM expects after conversion) -----
BASE_MODEL=microsoft/phi-2
# BASE_MODEL=distilgpt2

# ----- LoRA training -----
LORA_R=16
LORA_ALPHA=32
LORA_DROPOUT=0.05
LEARNING_RATE=2e-4
NUM_EPOCHS=3
BATCH_SIZE=2
GRAD_ACCUM_STEPS=4
MAX_SEQ_LENGTH=1024
USE_4BIT=true

# ----- Generation -----
GEN_TEMPERATURE=0.2
GEN_TOP_P=0.9
GEN_MAX_NEW_TOKENS=768
RAG_TOP_K=3

# ----- Inference backend: 'ollama' (default) or 'hf' (in-process transformers) -----
INFERENCE_BACKEND=ollama

# ----- Ollama -----
OLLAMA_HOST=ollama        # 'localhost' if running outside docker
OLLAMA_PORT=11434
OLLAMA_MODEL=spring-coder

# ----- GGUF quantization -----
QUANT=Q4_K_M              # Q4_K_M (default), Q5_K_M, Q8_0, etc.
KEEP_F16=false            # set true to retain the unquantized fp16 GGUF

# ----- Paths -----
ADAPTER_DIR=./adapters
MERGED_DIR=./adapters/merged
GGUF_DIR=./gguf
DATASET_PATH=./data/dto_controller_dataset.jsonl
EXAMPLES_DIR=./examples
MODELFILE_PATH=./Modelfile
CHROMA_COLLECTION=spring_java_examples
