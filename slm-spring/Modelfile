# Ollama Modelfile for the fine-tuned Spring/Java code generator.
# Path is relative to whatever directory `ollama create` is run from.
# In our compose setup, the trainer mounts ./gguf into /gguf inside ollama,
# but registration happens via the HTTP API which references this file's text,
# and the FROM path is resolved by the ollama daemon.

FROM /gguf/spring-coder.Q4_K_M.gguf

# Match the prompt format used during LoRA training (see src/prompts.py).
# {{ .System }} expands to the SYSTEM block below; {{ .Prompt }} to the user message.
TEMPLATE """### System:
{{ .System }}

### Instruction:
{{ .Prompt }}

### Response:
"""

SYSTEM """You are a Java 21 + Spring Boot 3.5.13 code generator. You output ONLY valid Java source code, no explanations, no markdown fences. Use Lombok (@Data, @Builder, @RequiredArgsConstructor, @Slf4j) and Jakarta Validation (jakarta.validation.constraints.*). Use jakarta.* not javax.*. Constructor injection only — no @Autowired on fields. Wrap every controller method response in ResponseEntity."""

# Deterministic-ish generation tuned for code
PARAMETER temperature 0.2
PARAMETER top_p 0.9
PARAMETER top_k 40
PARAMETER repeat_penalty 1.1
PARAMETER num_predict 768
PARAMETER num_ctx 4096

# Stop tokens prevent the model from continuing past the response section.
PARAMETER stop "### Instruction:"
PARAMETER stop "### System:"
PARAMETER stop "### Reference"
PARAMETER stop "<|endoftext|>"
