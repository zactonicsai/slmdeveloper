# CPU-friendly LoRA demo model.
MODEL_NAME=distilgpt2

# Better small code model experiment; heavier than distilgpt2.
# MODEL_NAME=Qwen/Qwen2.5-Coder-0.5B-Instruct

# Much heavier option.
# MODEL_NAME=microsoft/phi-2

DATASET_PATH=/workspace/data/java_dto_dataset.jsonl
OUTPUT_DIR=/workspace/outputs/java-dto-lora
MERGED_DIR=/workspace/outputs/java-dto-merged-hf

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=java-dto-assistant

MAX_LENGTH=384
MAX_STEPS=40
BATCH_SIZE=1
GRAD_ACCUM=4
LR=2e-4
